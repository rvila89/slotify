<mxfile host="app.diagrams.net">
  <diagram name="Página-1" id="CBX2byUC_f-yi0BpoW1S">
    <mxGraphModel dx="1414" dy="760" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="827" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="2" parent="1" style="fillColor=#F8CECC;strokeColor=#B85450;align=center;verticalAlign=middle;fontStyle=1;fontSize=12;whiteSpace=wrap;html=1;spacingTop=4;spacingLeft=6;" value="&lt;b&gt;PROBLEMA&lt;/b&gt;" vertex="1">
          <mxGeometry height="30" width="250" as="geometry" />
        </mxCell>
        <mxCell id="3" parent="1" style="fillColor=#FFFFFF;strokeColor=#B85450;align=left;verticalAlign=top;fontSize=10;whiteSpace=wrap;html=1;spacingTop=4;spacingLeft=6;" value="- Gestión dispersa en Gmail + Sheets + WhatsApp + Drive sin fuente única de verdad&#xa;- Cero visibilidad del pipeline de leads/consultas&#xa;- Sin estados claros de reserva → doble reserva&#xa;- Presupuestos manuales: 30-60 min cada uno&#xa;- Sin automatizaciones (emails y recordatorios manuales)&#xa;- Facturación dispersa sin conciliación&#xa;- Sin histórico centralizado ni consultable&#xa;- Decisiones por intuición, no por datos" vertex="1">
          <mxGeometry height="120" width="250" y="30" as="geometry" />
        </mxCell>
        <mxCell id="4" parent="1" style="fillColor=#D5E8D4;strokeColor=#82B366;align=center;verticalAlign=middle;fontStyle=1;fontSize=12;whiteSpace=wrap;html=1;spacingTop=4;spacingLeft=6;" value="&lt;b&gt;SEGMENTOS DE CLIENTES&lt;/b&gt;" vertex="1">
          <mxGeometry height="30" width="250" x="250" as="geometry" />
        </mxCell>
        <mxCell id="5" parent="1" style="fillColor=#FFFFFF;strokeColor=#82B366;align=left;verticalAlign=top;fontSize=10;whiteSpace=wrap;html=1;spacingTop=4;spacingLeft=6;" value="- Propietarios y gestores de espacios boutique de eventos&#xa;- Masías, fincas, villas, jardines, salones familiares&#xa;- Negocios familiares con 50-150 eventos/año&#xa;- Gestionan hoy con Gmail + Sheets + Drive + WhatsApp&#xa;- Caso piloto: Masia l&#39;Encís (Cataluña)&#xa;- Mercado inicial: España/Cataluña" vertex="1">
          <mxGeometry height="120" width="250" x="250" y="30" as="geometry" />
        </mxCell>
        <mxCell id="6" parent="1" style="fillColor=#FFF2CC;strokeColor=#D6B656;align=center;verticalAlign=middle;fontStyle=1;fontSize=12;whiteSpace=wrap;html=1;spacingTop=4;spacingLeft=6;" value="&lt;b&gt;PROPUESTA DE VALOR ÚNICA&lt;/b&gt;" vertex="1">
          <mxGeometry height="30" width="250" x="500" as="geometry" />
        </mxCell>
        <mxCell id="7" parent="1" style="fillColor=#FFFFFF;strokeColor=#D6B656;align=left;verticalAlign=top;fontSize=10;whiteSpace=wrap;html=1;spacingTop=4;spacingLeft=6;" value="- Plataforma operativa especializada que unifica el ciclo completo de eventos&#xa;- Elimina riesgo de doble reserva con bloqueo atómico&#xa;- Automatiza el 80% de comunicaciones y presupuestos&#xa;- Presupuestos en 30 seg vs 30-60 min&#xa;- Visibilidad operativa, financiera e histórica en tiempo real&#xa;- &quot;Gestiona toda tu masía desde un solo lugar&quot;" vertex="1">
          <mxGeometry height="120" width="250" x="500" y="30" as="geometry" />
        </mxCell>
        <mxCell id="8" parent="1" style="fillColor=#E1D5E7;strokeColor=#9673A6;align=center;verticalAlign=middle;fontStyle=1;fontSize=12;whiteSpace=wrap;html=1;spacingTop=4;spacingLeft=6;" value="&lt;b&gt;VENTAJA COMPETITIVA&lt;/b&gt;" vertex="1">
          <mxGeometry height="30" width="250" x="750" as="geometry" />
        </mxCell>
        <mxCell id="9" parent="1" style="fillColor=#FFFFFF;strokeColor=#9673A6;align=left;verticalAlign=top;fontSize=10;whiteSpace=wrap;html=1;spacingTop=4;spacingLeft=6;" value="- Conocimiento profundo del nicho &quot;masía familiar&quot; en España/Cataluña&#xa;- Modelo reserva-céntrico (vs cliente-céntrico de CRMs genéricos)&#xa;- Sub-procesos paralelos que reflejan la realidad operativa de eventos&#xa;- Cola automática de leads en fechas saturadas (ningún competidor)&#xa;- Detección de leads recurrentes con historial completo&#xa;- Bloqueo de fecha condicional según madurez del lead&#xa;- Idioma y normativa local española&#xa;- Time-to-value bajo (&lt;1 semana)&#xa;- Sustitución directa de Gmail + Sheets + Drive + WhatsApp&#xa;- CRMs genéricos no entienden recursos físicos limitados&#xa;- PMS hoteleros no contemplan eventos privados&#xa;- Software de bodas US no cubre propietarios de espacios" vertex="1">
          <mxGeometry height="420" width="250" x="750" y="30" as="geometry" />
        </mxCell>
        <mxCell id="10" parent="1" style="fillColor=#F8CECC;strokeColor=#B85450;align=center;verticalAlign=middle;fontStyle=1;fontSize=12;whiteSpace=wrap;html=1;spacingTop=4;spacingLeft=6;" value="&lt;b&gt;SOLUCIÓN&lt;/b&gt;" vertex="1">
          <mxGeometry height="30" width="250" y="150" as="geometry" />
        </mxCell>
        <mxCell id="11" parent="1" style="fillColor=#FFFFFF;strokeColor=#B85450;align=left;verticalAlign=top;fontSize=10;whiteSpace=wrap;html=1;spacingTop=4;spacingLeft=6;" value="- Pipeline completo: lead → consulta → pre-reserva → confirmada → ejecución → archivo&#xa;- Calendario con bloqueo atómico de fechas y TTLs&#xa;- Motor de tarifas + presupuestos PDF automáticos&#xa;- Facturación integrada (señal 40%, liquidación 60%, fianza)&#xa;- Sub-procesos paralelos (pre-evento + liquidación)&#xa;- Cola automática de leads en fechas bloqueadas&#xa;- Histórico consultable con búsqueda full-text&#xa;- Emails automáticos del flujo principal" vertex="1">
          <mxGeometry height="120" width="250" y="180" as="geometry" />
        </mxCell>
        <mxCell id="12" parent="1" style="fillColor=#D5E8D4;strokeColor=#82B366;align=center;verticalAlign=middle;fontStyle=1;fontSize=12;whiteSpace=wrap;html=1;spacingTop=4;spacingLeft=6;" value="&lt;b&gt;CANALES&lt;/b&gt;" vertex="1">
          <mxGeometry height="30" width="250" x="250" y="150" as="geometry" />
        </mxCell>
        <mxCell id="13" parent="1" style="fillColor=#FFFFFF;strokeColor=#82B366;align=left;verticalAlign=top;fontSize=10;whiteSpace=wrap;html=1;spacingTop=4;spacingLeft=6;" value="- Venta directa a masías y fincas&#xa;- Demo personalizada con piloto en Masia l&#39;Encís&#xa;- Red de conocidos del sector en Cataluña&#xa;- Marketing de contenido (blog, casos de éxito)&#xa;- Referidos de clientes satisfechos&#xa;- Presencia en ferias y eventos del sector bodas/eventos" vertex="1">
          <mxGeometry height="120" width="250" x="250" y="180" as="geometry" />
        </mxCell>
        <mxCell id="14" parent="1" style="fillColor=#DAE8FC;strokeColor=#6C8EBF;align=center;verticalAlign=middle;fontStyle=1;fontSize=12;whiteSpace=wrap;html=1;spacingTop=4;spacingLeft=6;" value="&lt;b&gt;FUENTES DE INGRESOS&lt;/b&gt;" vertex="1">
          <mxGeometry height="30" width="250" x="500" y="150" as="geometry" />
        </mxCell>
        <mxCell id="15" parent="1" style="fillColor=#FFFFFF;strokeColor=#6C8EBF;align=left;verticalAlign=top;fontSize=10;whiteSpace=wrap;html=1;spacingTop=4;spacingLeft=6;" value="- SaaS mensual: 50-150 €/mes por tenant&#xa;- Modelo multi-tenant: un tenant = un espacio&#xa;- Tier Premium (V4+) con IA, recomendador de tarifas dinámicas y marketplace&#xa;- Posible comisión por integración con proveedores/caterers (V3+)" vertex="1">
          <mxGeometry height="120" width="250" x="500" y="180" as="geometry" />
        </mxCell>
        <mxCell id="16" parent="1" style="fillColor=#DAE8FC;strokeColor=#6C8EBF;align=center;verticalAlign=middle;fontStyle=1;fontSize=12;whiteSpace=wrap;html=1;spacingTop=4;spacingLeft=6;" value="&lt;b&gt;ESTRUCTURA DE COSTES&lt;/b&gt;" vertex="1">
          <mxGeometry height="30" width="375" y="300" as="geometry" />
        </mxCell>
        <mxCell id="17" parent="1" style="fillColor=#FFFFFF;strokeColor=#6C8EBF;align=left;verticalAlign=top;fontSize=10;whiteSpace=wrap;html=1;spacingTop=4;spacingLeft=6;" value="- Desarrollo y mantenimiento del software (Next.js, Node.js, PostgreSQL)&#xa;- Infraestructura cloud: Vercel + Neon/Supabase&#xa;- Servicios externos: email (Resend/Postmark), pagos (Stripe), storage (R2/S3)&#xa;- Soporte al cliente y onboarding&#xa;- Marketing y ventas (bajo en MVP, escalable)&#xa;- Observabilidad: Sentry + PostHog" vertex="1">
          <mxGeometry height="120" width="375" y="330" as="geometry" />
        </mxCell>
        <mxCell id="18" parent="1" style="fillColor=#FFF2CC;strokeColor=#D6B656;align=center;verticalAlign=middle;fontStyle=1;fontSize=12;whiteSpace=wrap;html=1;spacingTop=4;spacingLeft=6;" value="&lt;b&gt;MÉTRICAS CLAVE&lt;/b&gt;" vertex="1">
          <mxGeometry height="30" width="375" x="375" y="300" as="geometry" />
        </mxCell>
        <mxCell id="19" parent="1" style="fillColor=#FFFFFF;strokeColor=#D6B656;align=left;verticalAlign=top;fontSize=10;whiteSpace=wrap;html=1;spacingTop=4;spacingLeft=6;" value="- Tasa de ocupación: días reservados / días disponibles&#xa;- Ratio consulta → reserva confirmada&#xa;- Tiempo medio consulta → confirmación&#xa;- Ticket medio por evento&#xa;- NPS post-evento&#xa;- Tasa de conversión desde cola&#xa;- DSO liquidación (días entre factura y cobro)&#xa;- Tasa de cancelación y motivos" vertex="1">
          <mxGeometry height="120" width="375" x="375" y="330" as="geometry" />
        </mxCell>
      </root>
