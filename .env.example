# Base de datos
DATABASE_URL="postgresql://user:password@localhost:5432/slotify_dev"

# JWT (usa secretos largos y aleatorios en producción)
JWT_ACCESS_SECRET="changeme-access-secret"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="changeme-refresh-secret"
JWT_REFRESH_EXPIRES_IN="7d"

# Email transaccional
RESEND_API_KEY="re_xxxx"
EMAIL_FROM="hola@slotify.app"

# Storage
STORAGE_BUCKET_URL="https://xxxxx.supabase.co/storage/v1"
STORAGE_SERVICE_KEY="changeme"

# App
API_PORT=3000
WEB_URL="http://localhost:5173"
NODE_ENV="development"

# Cron / barrido de expiración por TTL (US-012)
# Token service-to-service para el endpoint interno POST /api/cron/barrido-expiracion.
CRON_TOKEN="changeme-cron-token"
# Frecuencia del barrido (expresión cron). Por defecto, cada hora en el minuto 0.
CRON_BARRIDO_EXPIRACION="0 * * * *"
