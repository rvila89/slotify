    "@types/node": "^22.10.0",
    "dotenv": "^17.4.2",
    "jest": "^30.4.2",
    "prisma": "^6.2.0",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3"
  }
