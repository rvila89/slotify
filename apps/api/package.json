{
  "name": "@slotify/api",
  "version": "0.0.0",
  "private": true,
  "prisma": {
    "seed": "ts-node --compiler-options {\"module\":\"CommonJS\"} prisma/seed.ts"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "ts-node-dev --respawn --transpile-only -r dotenv/config src/main.ts",
    "start": "node dist/main.js",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "arch": "depcruise src",
    "test": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --runInBand && pnpm run arch",
    "test:e2e": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --runInBand --testPathPatterns=__tests__",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "db:seed": "prisma db seed"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.15",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.15",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.4.15",
    "@nestjs/schedule": "^4.1.2",
    "@nestjs/swagger": "^8.1.0",
    "@prisma/client": "^6.2.0",
    "@react-pdf/renderer": "^4.5.1",
    "argon2": "^0.41.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "cron": "^3.2.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "react": "^18.3.1",
    "reflect-metadata": "^0.2.2",
    "resend": "^6.16.0",
    "rxjs": "^7.8.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@nestjs/cli": "^10.4.9",
    "@nestjs/testing": "^10.4.15",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.10.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/react": "^18.3.31",
    "@types/supertest": "^6.0.2",
    "cross-env": "^10.1.0",
    "dependency-cruiser": "^17.4.3",
    "dotenv": "^17.4.2",
    "eslint": "^9.39.4",
    "globals": "^15.15.0",
    "jest": "^30.4.2",
    "prisma": "^6.2.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.61.1"
  }
}
