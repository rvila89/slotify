// Schema Prisma — Slotify MVP
// Fuente canónica: docs/er-diagram.md (v2.1) + docs/data-model.md (v1.0)
// Convenciones: modelos PascalCase ES + @@map snake_case; campos snake_case vía @map.
// Regla 1: todas las PK son UUID. Regla 2: tenant_id en toda tabla de negocio.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// ENUMS
// ============================================================

enum EstadoReserva {
  consulta
  pre_reserva
  reserva_confirmada
  evento_en_curso
  post_evento
  reserva_completada
  reserva_cancelada
}

enum SubEstadoConsulta {
  s2a // exploratoria
  s2b // con fecha
  s2c // pendiente invitados
  s2d // en cola
  s2v // visita programada
  s2x // expirada (terminal)
  s2y // descartada por cola (terminal)
  s2z // descartada por cliente (terminal)
}

enum TipoBloqueo {
  blando
  firme
}

enum Rol {
  gestor
  admin
  operario
}

enum CanalEntrada {
  web
  email
  whatsapp
  instagram
  telefono
  cocopool
  holaplace
}

enum DuracionHoras {
  h4  @map("4")
  h8  @map("8")
  h12 @map("12")
}

enum TipoEvento {
  boda
  corporativo
  privado
  otro
  cumpleanos
}

enum PreEventoStatus {
  pendiente
  en_curso
  cerrado
}

enum LiquidacionStatus {
  pendiente
  facturada
  cobrada
}

// fix-liquidacion-fianza-independientes: la fianza deja de ser una FACTURA que se emite.
// `cobrada` = comprobante de la transferencia recibida (subida pasiva por el gestor).
// `devuelta` = devolución completa registrada. Se eliminan `recibo_enviado` (ya no hay
// recibo emitido) y `retenida_parcial` (la devolución siempre es completa en MVP).
enum FianzaStatus {
  pendiente
  cobrada
  devuelta
}

enum Temporada {
  alta
  media
  baja
}

enum OrigenExtra {
  presupuesto
  anadido_post_confirmacion
}

enum EstadoPresupuesto {
  borrador
  enviado
  aceptado
  rechazado
}

// Épico #6, 6.2 (documentos-presupuesto-sin-iva-doble-numeracion, D1): método de pago
// elegido por el gestor y régimen fiscal derivado. `transferencia ⇒ con_iva`,
// `efectivo ⇒ sin_iva`. Se persisten AMBOS en Presupuesto (auditoría + doble numeración).
enum MetodoPago {
  transferencia
  efectivo
}

enum RegimenIva {
  con_iva
  sin_iva
}

// fix-liquidacion-fianza-independientes: se elimina `fianza` — la fianza ya no se factura.
enum TipoFactura {
  senal
  liquidacion
  complementaria
}

enum EstadoFactura {
  borrador
  enviada
  cobrada
}

enum TipoDocumento {
  dni_anverso
  dni_reverso
  clausula_responsabilidad
  condiciones_particulares
  justificante_pago
  // fix-liquidacion-fianza-independientes: comprobante de la transferencia de la fianza
  // recibida (subida pasiva por el gestor, espejo de condiciones_particulares).
  comprobante_fianza
  presupuesto
  factura
  otro
}

// fix-liquidacion-fianza-independientes: E10 = confirmación de fianza devuelta (nuevo,
// CA/ES). E5 (solicitud de IBAN) y E8 (confirmación de IBAN) dejan de usarse — sus
// plantillas/flujos se retiran; los valores del enum permanecen para no romper filas
// históricas (PostgreSQL no soporta DROP VALUE sin recrear el tipo).
enum CodigoEmail {
  E1
  E2
  E3
  E4
  E5
  E6
  E7
  E8
  E9
  E10
  manual
}

enum EstadoComunicacion {
  borrador
  enviado
  fallido
}

// historial-completo-comunicaciones (§D-subtipo) — Subtipo semántico del E1. Un mismo
// codigo_email='E1' agrupa emails distintos según el evento del ciclo de vida que lo
// dispara; el `subtipo` los distingue en el historial y en la etiqueta de UI. Es NULL
// para E2–E8, `manual` y filas legadas.
enum SubtipoEmail {
  consulta_exploratoria
  fecha_disponible
  fecha_confirmada
  cola_espera
  cambio_fecha
  solicitud_datos
}

enum AccionAudit {
  crear
  actualizar
  eliminar
  transicion
  login
  logout
}

// ============================================================
// NÚCLEO: TENANT, CONFIGURACIÓN, USUARIOS
// ============================================================

model Tenant {
  idTenant         String   @id @default(uuid()) @map("id_tenant")
  nombre           String
  emailContacto    String   @map("email_contacto")
  telefono         String?
  direccion        String?
  iban             String?
  nif              String?
  capacidadMaxima  Int?     @map("capacidad_maxima")
  activo           Boolean  @default(true)
  fechaCreacion    DateTime @default(now()) @map("fecha_creacion")
  fechaActualizacion DateTime @updatedAt @map("fecha_actualizacion")

  settings           TenantSettings?
  plantillaDocumento PlantillaDocumentoTenant?
  usuarios        Usuario[]
  clientes        Cliente[]
  reservas        Reserva[]
  fechasBloqueadas FechaBloqueada[]
  tarifas         Tarifa[]
  temporadas      TemporadaCalendario[]
  extras          Extra[]
  facturas        Factura[]
  presupuestos    Presupuesto[]
  documentos      Documento[]
  comunicaciones  Comunicacion[]
  auditLogs       AuditLog[]
  pagos           Pago[]

  @@map("tenant")
}

model TenantSettings {
  idSettings             String   @id @default(uuid()) @map("id_settings")
  tenantId               String   @unique @map("tenant_id")
  pctSenal               Decimal  @map("pct_senal") @db.Decimal(4, 2)
  fianzaDefaultEur       Decimal  @map("fianza_default_eur") @db.Decimal(10, 2)
  ttlConsultaDias        Int      @map("ttl_consulta_dias")
  ttlPrereservaDias      Int      @map("ttl_prereserva_dias")
  maxDiasProgramarVisita Int      @map("max_dias_programar_visita")
  idioma                 String   @default("es")
  fechaActualizacion     DateTime @updatedAt @map("fecha_actualizacion")

  tenant Tenant @relation(fields: [tenantId], references: [idTenant])

  @@map("tenant_settings")
}

// ============================================================
// PLANTILLA DE DOCUMENTO POR TENANT (épico #6, rebanada 6.1a)
// Contenido configurable de los documentos del tenant. 1-1 con Tenant.
// Fuente de verdad del contenido (decisión A1): duplica sus propios datos
// fiscales; NO toca Tenant.nombre/nif/direccion. RLS por migración.
// ============================================================

model PlantillaDocumentoTenant {
  idPlantilla               String   @id @default(uuid()) @map("id_plantilla")
  tenantId                  String   @unique @map("tenant_id")
  // Branding
  logoUrl                   String?  @map("logo_url")
  colorPrimario             String   @map("color_primario")
  colorTexto                String   @map("color_texto")
  // Identidad fiscal (razón social ≠ nombre comercial)
  razonSocialFiscal         String   @map("razon_social_fiscal")
  nombreComercial           String   @map("nombre_comercial")
  nif                       String
  direccionFiscal           String   @map("direccion_fiscal") @db.Text
  web                       String
  email                     String
  // Banca
  iban                      String
  beneficiarioTransferencia String   @map("beneficiario_transferencia")
  conceptoTransferencia     String   @map("concepto_transferencia")
  // Textos bilingües es/ca (change pdf-presupuesto-horario-idioma, Mejora 3): el PDF de
  // presupuesto elige el idioma según Reserva.idioma. Gestionados por seed/migración.
  plantillaConceptoFiscalCa String   @map("plantilla_concepto_fiscal_ca") @db.Text
  plantillaConceptoFiscalEs String   @map("plantilla_concepto_fiscal_es") @db.Text
  validesaTextoCa           String   @map("validesa_texto_ca")
  validesaTextoEs           String   @map("validesa_texto_es")
  pieLegalCa                String   @map("pie_legal_ca") @db.Text
  pieLegalEs                String   @map("pie_legal_es") @db.Text
  // Condicions particulars (épico #6, 6.4a; bilingüe en pdf-presupuesto-horario-idioma):
  // { titulo:{ca,es}, secciones:[{ titulo:{ca,es}, cuerpo:{ca,es} }] }. Default '{}' (no
  // destructivo): las filas existentes se rellenan por reseed del piloto.
  condiciones               Json     @default("{}") @map("condiciones")
  fechaCreacion             DateTime @default(now()) @map("fecha_creacion")
  fechaActualizacion        DateTime @updatedAt @map("fecha_actualizacion")

  tenant Tenant @relation(fields: [tenantId], references: [idTenant])

  @@map("plantilla_documento_tenant")
}

model Usuario {
  idUsuario          String    @id @default(uuid()) @map("id_usuario")
  tenantId           String    @map("tenant_id")
  email              String    @unique
  passwordHash       String    @map("password_hash")
  nombre             String
  apellidos          String?
  rol                Rol       @default(gestor)
  activo             Boolean   @default(true)
  ultimoAcceso       DateTime? @map("ultimo_acceso")
  fechaCreacion      DateTime  @default(now()) @map("fecha_creacion")
  fechaActualizacion DateTime  @updatedAt @map("fecha_actualizacion")

  tenant    Tenant     @relation(fields: [tenantId], references: [idTenant])
  auditLogs AuditLog[]

  @@map("usuario")
}

// ============================================================
// CLIENTES
// ============================================================

model Cliente {
  idCliente          String   @id @default(uuid()) @map("id_cliente")
  tenantId           String   @map("tenant_id")
  nombre             String
  apellidos          String?
  email              String?
  telefono           String?
  dniNif             String?  @map("dni_nif")
  direccion          String?
  codigoPostal       String?  @map("codigo_postal")
  poblacion          String?
  provincia          String?
  activo             Boolean  @default(true)
  fechaCreacion      DateTime @default(now()) @map("fecha_creacion")
  fechaActualizacion DateTime @updatedAt @map("fecha_actualizacion")

  tenant         Tenant         @relation(fields: [tenantId], references: [idTenant])
  reservas       Reserva[]
  comunicaciones Comunicacion[]

  @@index([tenantId, email])
  @@map("cliente")
}

// ============================================================
// RESERVA (ENTIDAD CENTRAL ÚNICA)
// ============================================================

model Reserva {
  idReserva               String             @id @default(uuid()) @map("id_reserva")
  tenantId                String             @map("tenant_id")
  clienteId               String             @map("cliente_id")
  codigo                  String             @unique
  estado                  EstadoReserva
  subEstado               SubEstadoConsulta? @map("sub_estado")
  canalEntrada            CanalEntrada       @map("canal_entrada")
  fechaEvento             DateTime?          @map("fecha_evento") @db.Date
  duracionHoras           DuracionHoras?     @map("duracion_horas")
  tipoEvento              TipoEvento?        @map("tipo_evento")
  numAdultosNinosMayores4 Int?               @map("num_adultos_ninos_mayores4")
  numNinosMenores4        Int?               @map("num_ninos_menores4")
  numInvitadosFinal       Int?               @map("num_invitados_final")
  importeTotal            Decimal?           @map("importe_total") @db.Decimal(10, 2)
  importeSenal            Decimal?           @map("importe_senal") @db.Decimal(10, 2)
  importeLiquidacion      Decimal?           @map("importe_liquidacion") @db.Decimal(10, 2)
  ttlExpiracion           DateTime?          @map("ttl_expiracion")
  preEventoStatus         PreEventoStatus    @default(pendiente) @map("pre_evento_status")
  liquidacionStatus       LiquidacionStatus  @default(pendiente) @map("liquidacion_status")
  fianzaStatus            FianzaStatus       @default(pendiente) @map("fianza_status")
  // US-037 (D-2=A): timestamp de ENTRADA a `post_evento`, fuente de verdad del reloj T+7d del
  // archivado automático. Nullable (migración no destructiva); se puebla en la MISMA transacción
  // que fija `estado = post_evento` (US-034). Inmune a `@updatedAt` (a diferencia de
  // `fechaActualizacion`). El residual pre-migración se backfillea desde AUDIT_LOG.
  fechaPostEvento         DateTime?          @map("fecha_post_evento")
  posicionCola            Int?               @map("posicion_cola")
  consultaBloqueanteId    String?            @map("consulta_bloqueante_id")
  visitaProgramadaFecha   DateTime?          @map("visita_programada_fecha") @db.Date
  visitaProgramadaHora    String?            @map("visita_programada_hora")
  visitaRealizada         Boolean            @default(false) @map("visita_realizada")
  fianzaEur               Decimal?           @map("fianza_eur") @db.Decimal(10, 2)
  // fix-liquidacion-fianza-independientes: `fianzaCobradaFecha` se puebla al subir el
  // comprobante (fianza pasiva); `fianzaComprobanteFecha` marca la subida (espejo de
  // `condPartFirmadasFecha`). Se eliminan `fianzaDevueltaEur` y `motivoRetencion`
  // (devolución siempre completa = `fianzaEur`, sin retención parcial).
  fianzaCobradaFecha      DateTime?          @map("fianza_cobrada_fecha")
  fianzaComprobanteFecha  DateTime?          @map("fianza_comprobante_fecha")
  fianzaDevueltaFecha     DateTime?          @map("fianza_devuelta_fecha")
  condPartFirmadas        Boolean            @default(false) @map("cond_part_firmadas")
  condPartEnviadasFecha   DateTime?          @map("cond_part_enviadas_fecha")
  condPartFirmadasFecha   DateTime?          @map("cond_part_firmadas_fecha")
  idioma                  String             @default("es") @map("idioma")
  horario                 String?            @map("horario")
  notas                   String?            @db.Text
  comentarios             String?            @map("comentarios") @db.Text
  activo                  Boolean            @default(true)
  fechaCreacion           DateTime           @default(now()) @map("fecha_creacion")
  fechaActualizacion      DateTime           @updatedAt @map("fecha_actualizacion")

  tenant            Tenant           @relation(fields: [tenantId], references: [idTenant])
  cliente           Cliente          @relation(fields: [clienteId], references: [idCliente])
  consultaBloqueante Reserva?        @relation("ColaEspera", fields: [consultaBloqueanteId], references: [idReserva])
  enCola            Reserva[]        @relation("ColaEspera")
  fechaBloqueada    FechaBloqueada?
  presupuestos      Presupuesto[]
  reservaExtras     ReservaExtra[]
  facturas          Factura[]
  fichaOperativa    FichaOperativa?
  documentos        Documento[]
  comunicaciones    Comunicacion[]

  @@index([tenantId, fechaEvento, estado])
  @@index([tenantId, consultaBloqueanteId, posicionCola])
  // US-037 (D-2=A): índice de apoyo al filtro de candidatas del barrido de archivado
  // (`estado = 'post_evento'` AND `fecha_post_evento <= hoy - 7d`). Selección cross-tenant.
  @@index([estado, fechaPostEvento])
  // US-004 §D-8: índice UNIQUE PARCIAL `reserva_cola_posicion_key` sobre
  // (tenant_id, consulta_bloqueante_id, posicion_cola) WHERE posicion_cola IS NOT NULL,
  // creado por migración SQL cruda (Prisma no soporta índices parciales en el schema).
  @@map("reserva")
}

// ============================================================
// BLOQUEO ATÓMICO DE FECHAS — UNIQUE(tenant_id, fecha)
// ============================================================

model FechaBloqueada {
  idBloqueo     String      @id @default(uuid()) @map("id_bloqueo")
  tenantId      String      @map("tenant_id")
  fecha         DateTime    @db.Date
  reservaId     String      @unique @map("reserva_id")
  tipoBloqueo   TipoBloqueo @map("tipo_bloqueo")
  ttlExpiracion DateTime?   @map("ttl_expiracion")
  fechaCreacion DateTime    @default(now()) @map("fecha_creacion")

  tenant  Tenant  @relation(fields: [tenantId], references: [idTenant])
  reserva Reserva @relation(fields: [reservaId], references: [idReserva])

  @@unique([tenantId, fecha]) // GARANTÍA ATÓMICA ANTI-DOBLE-RESERVA
  @@map("fecha_bloqueada")
}

// ============================================================
// TARIFAS Y EXTRAS
// ============================================================

model Tarifa {
  idTarifa           String    @id @default(uuid()) @map("id_tarifa")
  tenantId           String    @map("tenant_id")
  temporada          Temporada
  duracionHoras      Int       @map("duracion_horas")
  invitadosMin       Int       @map("invitados_min")
  invitadosMax       Int       @map("invitados_max")
  precioTotalEur     Decimal   @map("precio_total_eur") @db.Decimal(10, 2)
  vigenteDesde       DateTime  @map("vigente_desde") @db.Date
  vigenteHasta       DateTime? @map("vigente_hasta") @db.Date
  activo             Boolean   @default(true)
  fechaCreacion      DateTime  @default(now()) @map("fecha_creacion")
  fechaActualizacion DateTime  @updatedAt @map("fecha_actualizacion")

  tenant Tenant @relation(fields: [tenantId], references: [idTenant])

  @@map("tarifa")
}

model TemporadaCalendario {
  idTemporadaCal String    @id @default(uuid()) @map("id_temporada_cal")
  tenantId       String    @map("tenant_id")
  temporada      Temporada
  mes            Int

  tenant Tenant @relation(fields: [tenantId], references: [idTenant])

  @@map("temporada_calendario")
}

model Extra {
  idExtra            String   @id @default(uuid()) @map("id_extra")
  tenantId           String   @map("tenant_id")
  nombre             String
  descripcion        String?
  precioEur          Decimal  @map("precio_eur") @db.Decimal(10, 2)
  activo             Boolean  @default(true)
  fechaCreacion      DateTime @default(now()) @map("fecha_creacion")
  fechaActualizacion DateTime @updatedAt @map("fecha_actualizacion")

  tenant        Tenant         @relation(fields: [tenantId], references: [idTenant])
  reservaExtras ReservaExtra[]

  @@map("extra")
}

model ReservaExtra {
  idReservaExtra String      @id @default(uuid()) @map("id_reserva_extra")
  reservaId      String      @map("reserva_id")
  extraId        String?     @map("extra_id")
  facturaId      String?     @map("factura_id")
  conceptoLibre  String?     @map("concepto_libre")
  origen         OrigenExtra
  cantidad       Int
  precioUnitario Decimal     @map("precio_unitario") @db.Decimal(10, 2)
  subtotal       Decimal     @db.Decimal(10, 2)
  fechaCreacion  DateTime    @default(now()) @map("fecha_creacion")

  reserva Reserva  @relation(fields: [reservaId], references: [idReserva])
  extra   Extra?   @relation(fields: [extraId], references: [idExtra])
  factura Factura? @relation(fields: [facturaId], references: [idFactura])

  @@map("reserva_extra")
}

// ============================================================
// PRESUPUESTOS
// ============================================================

model Presupuesto {
  idPresupuesto      String            @id @default(uuid()) @map("id_presupuesto")
  tenantId           String?           @map("tenant_id")
  reservaId          String            @map("reserva_id")
  numeroPresupuesto  String?           @map("numero_presupuesto")
  version            Int
  baseImponible      Decimal           @map("base_imponible") @db.Decimal(10, 2)
  ivaPorcentaje      Decimal           @map("iva_porcentaje") @db.Decimal(4, 2)
  ivaImporte         Decimal           @map("iva_importe") @db.Decimal(10, 2)
  total              Decimal           @db.Decimal(10, 2)
  descuentoEur       Decimal?          @map("descuento_eur") @db.Decimal(10, 2)
  descuentoMotivo    String?           @map("descuento_motivo")
  tarifaCongelada    Boolean           @default(true) @map("tarifa_congelada")
  pdfUrl             String?           @map("pdf_url")
  estado             EstadoPresupuesto
  // change `reserva-viva-edicion-recalculo-ficha` (§D-5): ORIGEN de la versión. NULL para
  // las versiones normales (presupuesto inicial/edición en pre_reserva); `modificacion` para
  // la versión creada por el recálculo en la ventana viva tras confirmar la señal (pago
  // inicial fijo + liquidación restante, sin reparto 40/60). Migración aditiva/nullable.
  origen             String?           @map("origen")
  // Épico #6, 6.2 (D1): método de pago elegido + régimen fiscal derivado. Nullable
  // (migración aditiva); backfill `transferencia`/`con_iva` para las filas de 6.1b. La app
  // siempre escribe ambos al crear.
  metodoPago         MetodoPago?       @map("metodo_pago")
  regimenIva         RegimenIva?       @map("regimen_iva")
  fechaEnvio         DateTime?         @map("fecha_envio")
  fechaCreacion      DateTime          @default(now()) @map("fecha_creacion")
  fechaActualizacion DateTime          @updatedAt @map("fecha_actualizacion")

  reserva Reserva @relation(fields: [reservaId], references: [idReserva])
  tenant  Tenant? @relation(fields: [tenantId], references: [idTenant])

  // Épico #6, 6.1b (N1/N2) + 6.2 (D2 Opción A): numeración `AAAANNN` por tenant, año y
  // RÉGIMEN (el año va embebido en el literal). La unicidad incluye `regimenIva` para que
  // CON y SIN mantengan secuencias independientes que pueden compartir el mismo literal
  // (`2026001` en CON y en SIN sin colisión). NULL mientras no se confirma (los NULL no
  // colisionan en PostgreSQL). El reintento ante colisión (P2002) vive en el use-case.
  @@unique([reservaId, version])
  @@unique([tenantId, regimenIva, numeroPresupuesto])
  @@map("presupuesto")
}

// ============================================================
// FACTURAS Y PAGOS
// ============================================================

model Factura {
  idFactura          String        @id @default(uuid()) @map("id_factura")
  tenantId           String        @map("tenant_id")
  reservaId          String        @map("reserva_id")
  numeroFactura      String?       @map("numero_factura")
  tipo               TipoFactura
  baseImponible      Decimal       @map("base_imponible") @db.Decimal(10, 2)
  ivaPorcentaje      Decimal       @map("iva_porcentaje") @db.Decimal(4, 2)
  ivaImporte         Decimal       @map("iva_importe") @db.Decimal(10, 2)
  total              Decimal       @db.Decimal(10, 2)
  concepto           String?
  pdfUrl             String?       @map("pdf_url")
  estado             EstadoFactura
  fechaEmision       DateTime?     @map("fecha_emision")
  fechaCreacion      DateTime      @default(now()) @map("fecha_creacion")
  fechaActualizacion DateTime      @updatedAt @map("fecha_actualizacion")

  tenant        Tenant         @relation(fields: [tenantId], references: [idTenant])
  reserva       Reserva        @relation(fields: [reservaId], references: [idReserva])
  reservaExtras ReservaExtra[]
  pagos         Pago[]

  // US-022 (§D-7): numeración fiscal secuencial por tenant (el año va embebido en el
  // literal F-YYYY-NNNN) — sustituye al @unique global sobre numero_factura, permitiendo
  // que dos tenants distintos tengan F-2026-0001. Idempotencia de una factura por
  // (reserva, tipo): red de seguridad ante disparos concurrentes del trigger post-commit.
  @@unique([tenantId, numeroFactura])
  @@unique([reservaId, tipo])
  @@map("factura")
}

model Pago {
  idPago            String   @id @default(uuid()) @map("id_pago")
  tenantId          String   @map("tenant_id")
  facturaId         String   @map("factura_id")
  importe           Decimal  @db.Decimal(10, 2)
  fechaCobro        DateTime @map("fecha_cobro") @db.Date
  justificanteDocId String?  @map("justificante_doc_id")
  fechaCreacion     DateTime @default(now()) @map("fecha_creacion")

  tenant       Tenant     @relation(fields: [tenantId], references: [idTenant])
  factura      Factura    @relation(fields: [facturaId], references: [idFactura])
  justificante Documento? @relation(fields: [justificanteDocId], references: [idDocumento])

  // US-029 (D-1): tenant_id explícito en PAGO (regla dura multi-tenancy/RLS del proyecto).
  // Cardinalidad FACTURA 1—N PAGO SIN UNIQUE(factura_id): la unicidad de cobro del MVP la
  // garantiza la guarda de estado (liquidacion_status) bajo SELECT ... FOR UPDATE, previendo
  // cobros parciales futuros.
  @@index([tenantId])
  @@index([facturaId])
  @@map("pago")
}

// ============================================================
// FICHA OPERATIVA
// ============================================================

model FichaOperativa {
  idFicha                String    @id @default(uuid()) @map("id_ficha")
  reservaId              String    @unique @map("reserva_id")
  numInvitadosConfirmado Int?      @map("num_invitados_confirmado")
  // Campos legacy (soft-remove del contrato ficha-operativa-campos-operativos): las
  // columnas PERMANECEN en BD como nullable, pero ya NO se proyectan al dominio ni al
  // contrato. No borrar sin una migración de datos posterior.
  menuSeleccionado       String?   @map("menu_seleccionado") @db.Text
  timingDetallado        String?   @map("timing_detallado") @db.Text
  contactoEventoNombre   String?   @map("contacto_evento_nombre")
  contactoEventoTelefono String?   @map("contacto_evento_telefono")
  contactoEventoCorreo   String?   @map("contacto_evento_correo")
  horaLlegada            String?   @map("hora_llegada")
  duracion               String?   @map("duracion")
  notasOperativas        String?   @map("notas_operativas") @db.Text
  briefingEquipo         String?   @map("briefing_equipo") @db.Text
  fichaCerrada           Boolean   @default(false) @map("ficha_cerrada")
  fechaCierre            DateTime? @map("fecha_cierre")
  fechaCreacion          DateTime  @default(now()) @map("fecha_creacion")
  fechaActualizacion     DateTime  @updatedAt @map("fecha_actualizacion")

  reserva Reserva @relation(fields: [reservaId], references: [idReserva])

  @@map("ficha_operativa")
}

// ============================================================
// DOCUMENTOS POLIMÓRFICOS
// ============================================================

model Documento {
  idDocumento   String        @id @default(uuid()) @map("id_documento")
  tenantId      String        @map("tenant_id")
  reservaId     String?       @map("reserva_id")
  tipo          TipoDocumento
  nombreArchivo String        @map("nombre_archivo")
  url           String
  mimeType      String        @map("mime_type")
  tamanoBytes   Int?          @map("tamano_bytes")
  fechaCreacion DateTime      @default(now()) @map("fecha_creacion")

  tenant  Tenant   @relation(fields: [tenantId], references: [idTenant])
  reserva Reserva? @relation(fields: [reservaId], references: [idReserva])
  pagos   Pago[]

  @@map("documento")
}

// ============================================================
// COMUNICACIONES
// ============================================================

model Comunicacion {
  idComunicacion    String             @id @default(uuid()) @map("id_comunicacion")
  tenantId          String             @map("tenant_id")
  reservaId         String?            @map("reserva_id")
  clienteId         String             @map("cliente_id")
  codigoEmail       CodigoEmail        @map("codigo_email")
  asunto            String
  cuerpo            String?            @db.Text
  destinatarioEmail String             @map("destinatario_email")
  estado            EstadoComunicacion
  fechaEnvio        DateTime?          @map("fecha_envio")
  fechaCreacion     DateTime           @default(now()) @map("fecha_creacion")
  // US-028 (D-4) — Marca de reenvío manual del Gestor. Los reenvíos quedan FUERA del
  // índice de idempotencia parcial (permiten múltiples COMUNICACION E4 por reserva).
  esReenvio         Boolean            @default(false) @map("es_reenvio")
  // historial-completo-comunicaciones (§D-subtipo) — Subtipo semántico del E1 (NULL para
  // E2–E8, `manual` y filas legadas). Participa en el índice UNIQUE parcial de la terna.
  subtipo           SubtipoEmail?      @map("subtipo")

  tenant  Tenant   @relation(fields: [tenantId], references: [idTenant])
  reserva Reserva? @relation(fields: [reservaId], references: [idReserva])
  cliente Cliente  @relation(fields: [clienteId], references: [idCliente])

  // historial-completo-comunicaciones (§D-indice-terna) — Idempotencia clavada sobre la
  // TERNA `(reserva_id, codigo_email, subtipo)`. Índice UNIQUE PARCIAL
  // `uq_comunicacion_reserva_codigo (reserva_id, codigo_email, subtipo) NULLS NOT
  // DISTINCT WHERE reserva_id IS NOT NULL AND es_reenvio = false AND codigo_email <>
  // 'manual' AND estado = 'enviado'` creado por SQL crudo (Prisma no modela ni el
  // predicado WHERE ni `NULLS NOT DISTINCT`).
  //
  // Semántica del historial: el predicado `estado = 'enviado'` permite ILIMITADOS
  // `borrador` de cualquier subtipo (historial completo por evento: alta/añadir/cambiar
  // fecha), y que subtipos DISTINTOS lleguen ambos a `enviado` (emails legítimos
  // distintos, NO reenvíos). Solo un SEGUNDO envío de la MISMA terna colisiona (backstop
  // de la carrera de doble envío idéntico).
  //
  // `NULLS NOT DISTINCT` (Postgres 15) es CRÍTICO: preserva la idempotencia de E2–E8
  // (subtipo = NULL) — dos filas `enviado` de la misma `(reserva, codigo, NULL)` siguen
  // colisionando —, mientras que los E1 con subtipos NO nulos distintos coexisten.
  //
  // Quedan EXCLUIDOS del constraint: los reenvíos manuales (es_reenvio = true, US-028
  // D-4, patrón E3/E4/E8) y los emails `manual` (US-046 D-5 Opción C), por su predicado.
  @@map("comunicacion")
}

// ============================================================
// AUDIT LOG
// ============================================================

model AuditLog {
  idAudit         String      @id @default(uuid()) @map("id_audit")
  tenantId        String      @map("tenant_id")
  usuarioId       String?     @map("usuario_id")
  entidad         String
  entidadId       String      @map("entidad_id")
  accion          AccionAudit
  datosAnteriores Json?       @map("datos_anteriores")
  datosNuevos     Json?       @map("datos_nuevos")
  ipAddress       String?     @map("ip_address")
  userAgent       String?     @map("user_agent")
  fechaCreacion   DateTime    @default(now()) @map("fecha_creacion")

  tenant  Tenant   @relation(fields: [tenantId], references: [idTenant])
  usuario Usuario? @relation(fields: [usuarioId], references: [idUsuario])

  @@map("audit_log")
}
