{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(pnpm test:*)",
      "Bash(pnpm lint:*)",
      "Bash(pnpm typecheck:*)",
      "Bash(pnpm generate:api:*)",
      "Bash(pnpm prisma:*)",
      "Bash(openspec:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(spectral lint:*)",
      "Bash(redocly lint:*)",
      "Bash(python3 scripts/extract_backlog.py:*)",
      "Read",
      "Grep",
      "Glob"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./apps/api/.env)",
      "Read(./apps/web/.env)",
      "Read(./**/*.pem)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          { "type": "command", "command": "python \"$CLAUDE_PROJECT_DIR/scripts/hooks/no-infra-in-domain.py\"" },
          { "type": "command", "command": "python \"$CLAUDE_PROJECT_DIR/scripts/hooks/no-distributed-lock.py\"" },
          { "type": "command", "command": "python \"$CLAUDE_PROJECT_DIR/scripts/hooks/protect-generated-client.py\"" },
          { "type": "command", "command": "python \"$CLAUDE_PROJECT_DIR/scripts/hooks/require-tests-first.py\"" }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "python \"$CLAUDE_PROJECT_DIR/scripts/hooks/require-code-review.py\"" }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          { "type": "command", "command": "python \"$CLAUDE_PROJECT_DIR/scripts/hooks/validate-openapi.py\"" }
        ]
      }
    ]
  }
}
